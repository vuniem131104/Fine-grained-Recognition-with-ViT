KSERVE_MODEL_URL=                   # KServe inference endpoint URL for the bird classification model

ZONE=                               # GCP region/zone (e.g. us-central1)

LOKI_CHUNKS_BUCKET_NAME=            # GCS bucket name for Loki log chunks
LOKI_RULER_BUCKET_NAME=             # GCS bucket name for Loki ruler data
MLFLOW_BUCKET_NAME=                 # GCS bucket name for MLflow artifacts
MODEL_BUCKET_NAME=                  # GCS bucket name for storing model files
TEMPO_TRACES_BUCKET_NAME=           # GCS bucket name for Tempo trace data

SQL_INSTANCE_NAME=                  # Cloud SQL instance name
POSTGRES_USER=                      # PostgreSQL username
POSTGRES_PASSWORD=                  # PostgreSQL password
POSTGRES_HOST=                      # PostgreSQL host (e.g. localhost or Cloud SQL proxy)
POSTGRES_PORT=                      # PostgreSQL port (default: 5432)
MLFLOW_DB=                          # Database name used by MLflow
MAIN_DB=                            # Main application database name

LOKI_SA_NAME=                       # GCP service account name for Loki
FRONTEND_SA_NAME=                   # GCP service account name for the frontend service
TEMPO_SA_NAME=                      # GCP service account name for Tempo
MLFLOW_SA_NAME=                     # GCP service account name for MLflow
MLFLOW_CREDENTIALS=                 # Filename of the MLflow service account JSON key
KSERVE_SA_NAME=                     # GCP service account name for KServe
API_SA_NAME=                        # GCP service account name for API server  
GITHUB_ACTIONS_SA_NAME=             # GCP service account name for GitHub Actions CI/CD

PRODUCTION_NAMESPACE=               # Kubernetes namespace for production workloads
MONITORING_NAMESPACE=               # Kubernetes namespace for monitoring stack

ARTIFACT_REPO=                      # Artifact Registry repository name

USER_EMAIL=                         # GCP user/service account email prefix

GKE_CLUSTER_NAME=                   # GKE cluster name

GOOGLE_APPLICATION_CREDENTIALS=     # Path to GCP service account JSON key file

MODEL_NAME=                         # Registered model name in MLflow
MODEL_VERSION=                      # Model version to serve

MLFLOW_TRACKING_URI=                # URI of the MLflow tracking server
MLFLOW_EXPERIMENT_NAME=             # MLflow experiment name for training runs

HTTP_PORT=                          # HTTP port the API server listens on
WORKERS=                            # Number of Gunicorn/Uvicorn worker processes
API_URL=                            # Internal URL used by the frontend to reach the API